ARG WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE
FROM ${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE}

ARG WHODOIRUNLIKE_BENCHMARK_VERSION=unknown
ARG WHODOIRUNLIKE_FINAL_CANDIDATE_COMMIT
ARG WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST
ARG WHODOIRUNLIKE_FINAL_PRODUCTION_SHA256_B64

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    WHODOIRUNLIKE_ENABLE_SAM31_BENCHMARK=true \
    WHODOIRUNLIKE_ENVIRONMENT=benchmark \
    WHODOIRUNLIKE_BENCHMARK_VERSION=${WHODOIRUNLIKE_BENCHMARK_VERSION} \
    WHODOIRUNLIKE_BENCHMARK_IMAGE_ROLE=final_candidate \
    WHODOIRUNLIKE_BASE_PROCESSOR_COMMIT=${WHODOIRUNLIKE_FINAL_CANDIDATE_COMMIT} \
    WHODOIRUNLIKE_BASE_PROCESSOR_IMAGE_DIGEST=${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST} \
    WHODOIRUNLIKE_CANDIDATE_COMMIT=${WHODOIRUNLIKE_FINAL_CANDIDATE_COMMIT} \
    WHODOIRUNLIKE_CANDIDATE_IMAGE_DIGEST=${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST} \
    WHODOIRUNLIKE_CODE_OVERLAY_SOURCE=base_image \
    WHODOIRUNLIKE_CODE_OVERLAY_COMMIT=${WHODOIRUNLIKE_FINAL_CANDIDATE_COMMIT} \
    WHODOIRUNLIKE_CODE_OVERLAY_REFERENCE_IMAGE_DIGEST=${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST} \
    WHODOIRUNLIKE_DEPENDENCY_BASE_ROLE=final_candidate \
    WHODOIRUNLIKE_DEPENDENCY_BASE_COMMIT=${WHODOIRUNLIKE_FINAL_CANDIDATE_COMMIT} \
    WHODOIRUNLIKE_DEPENDENCY_BASE_IMAGE_DIGEST=${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST} \
    WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_REFERENCE=ghcr.io/akhil-ghosh/whodoirunlike-runpod-processor@${WHODOIRUNLIKE_FINAL_CANDIDATE_IMAGE_DIGEST} \
    WHODOIRUNLIKE_FINAL_PRODUCTION_SHA256_B64=${WHODOIRUNLIKE_FINAL_PRODUCTION_SHA256_B64} \
    WHODOIRUNLIKE_ENFORCE_BASE_CONTRACT=true \
    WHODOIRUNLIKE_MASK_BACKEND=sam31_gpu \
    MMPOSE_DEVICE=cpu \
    RTMW_RUNTIME_BACKEND=onnxruntime

WORKDIR /app

# The final candidate already contains production code, models, and dependencies.
# Add only the isolated parity harness; production modules are verified in place.
COPY src/whodoirunlike/sam31_parity.py /app/src/whodoirunlike/sam31_parity.py
COPY src/whodoirunlike/sam31_benchmark.py /app/src/whodoirunlike/sam31_benchmark.py
COPY src/whodoirunlike/pipeline_parity.py /app/src/whodoirunlike/pipeline_parity.py
COPY src/whodoirunlike/sam31_benchmark_serverless.py /app/src/whodoirunlike/sam31_benchmark_serverless.py

CMD ["python", "-m", "whodoirunlike.sam31_benchmark_serverless"]
