{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://whodoirunlike.com/schemas/active_learning_queue.schema.json",
  "title": "Active Learning Uncertainty Queue",
  "type": "object",
  "required": ["version", "queue_type", "entry_count", "entries"],
  "properties": {
    "version": { "const": 1 },
    "created_at": { "type": "string" },
    "queue_type": { "const": "active_learning_uncertainty" },
    "entry_count": { "type": "integer", "minimum": 0 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate_id", "run_dir", "uncertainty_score", "reason_tags"],
        "properties": {
          "candidate_id": { "type": "string" },
          "runner_name": { "type": ["string", "null"] },
          "run_dir": { "type": "string" },
          "uncertainty_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "reason_tags": { "type": "array", "items": { "type": "string" } },
          "review_url_hint": { "type": "string" },
          "qc_metrics": { "type": "string" }
        }
      }
    }
  }
}
